# OpenClawSkills Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to version control.

# API Keys — only needed if using InstructionCompiler in LLM-assisted mode
# All keys are stored as SecretStr and never logged or serialized.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=

# Local model endpoint (Ollama, vLLM, llama.cpp)
OLLAMA_API_BASE=http://localhost:11434

# Network security
# OPENCLAW_PROXY_URL=socks5://127.0.0.1:9050
# OPENCLAW_TLS_CERT_PATH=/path/to/ca-bundle.crt
OPENCLAW_VERIFY_TLS=true

# Logging
OPENCLAW_LOG_LEVEL=INFO
OPENCLAW_LOG_FORMAT=json

# Storage paths (relative to working directory)
OPENCLAW_STATE_DIR=.openclaw/state
OPENCLAW_AUDIT_DIR=.openclaw/audit
